{
  "name": "lost-and-found-api",
  "version": "1.0.0",
  "description": "Lost & Found REST API — runs on AWS ECS",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy"
  },
  "dependencies": {
    "@aws-sdk/client-sesv2": "^3.750.0",
    "@prisma/client": "^7.0.0",
    "bcryptjs": "^3.0.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "jose": "^6.0.0",
    "prisma": "^7.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
